<Window
    x:Class="Labyrinthe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Labyrinthe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="1600"
    Height="900"
    KeyDown="Joueur_KeyDown"
    KeyUp="Joueur_KeyUp"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Canvas x:Name="fondJeu" Background="#FFB9B9B9">
        <Image
            x:Name="Joueur"
            Canvas.Left="10"
            Canvas.Top="842"
            Width="32"
            Height="32"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            RenderTransformOrigin="0.5,0.5"
            Source="img/PapaNoel/PapaNoel.gif">
            <Image.RenderTransform>
                <RotateTransform x:Name="ImageRotation" Angle="0" />
            </Image.RenderTransform>
        </Image>
        <Image
            x:Name="Cadeaux1"
            Canvas.Left="17"
            Canvas.Top="192"
            Width="32"
            Height="32"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Stretch="Fill"
            Source="/img/Cadeaux/Gift.png"
            >

        </Image>
        <Label
            x:Name="NbPointLab"
            Canvas.Top="-2"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Content="Cadeaux :"
            FontSize="30" />

        <Label
            x:Name="NbPoint"
            Canvas.Left="134"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="0"
            FontSize="30" />
        <ProgressBar
            x:Name="progressBar"
            Width="1600"
            Height="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Center" />
        <Rectangle
            x:Name="Sapin"
            Canvas.Left="801"
            Canvas.Top="400"
            Width="64"
            Height="64"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" />
        <Label
            x:Name="msmCadeaux"
            Canvas.Left="517"
            Canvas.Top="15"
            Background="Red"
            Content="Vous ne pouvez pas prendre plus de 3 cadeaux"
            FontSize="30"
            Foreground="White"
            Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Top" />
        <Label
            x:Name="NbPointDeposeLab"
            Canvas.Top="40"
            Content="Cadeaux déposé :"
            FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Top" />
        <Label
            x:Name="NbPointDepose"
            Canvas.Left="243"
            Content="0"
            FontSize="30" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Top="40" />




    </Canvas>
</Window>
