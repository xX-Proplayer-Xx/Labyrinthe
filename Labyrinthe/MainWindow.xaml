<Window
    x:Class="Labyrinthe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Labyrinthe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="1600"
    Height="900"
    KeyDown="Joueur_KeyDown"
    KeyUp="Joueur_KeyUp"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Canvas x:Name="fondJeu">
        <Canvas.Background>
            <ImageBrush ImageSource="/imageFondJeu.png" />
        </Canvas.Background>

        <StackPanel
            Name="FinPartiePanel"
            Canvas.Left="656"
            Canvas.Top="480"
            Width="296"
            Height="174"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Panel.ZIndex="1"
            Background="Black"
            Visibility="Hidden">
            <TextBlock
                x:Name="TextBlockRes"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                FontSize="20"
                Foreground="White"
                Text=""
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="TempsEcouleText"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                FontSize="20"
                Foreground="White"
                Text="Temps Écoulé : 00:00" />
            <Button
                x:Name="RejouerButton"
                Canvas.Left="73"
                Canvas.Top="87"
                Width="150"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="White"
                BorderBrush="White"
                Click="RejouerButton_Click"
                Content="Rejouer" />

            <Button
                x:Name="MenuButton"
                Canvas.Left="73"
                Canvas.Top="126"
                Width="150"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="White"
                BorderBrush="White"
                Click="MenuButton_Click"
                Content="Menu Accueil" />

        </StackPanel>
        <Image
            x:Name="Joueur"
            Canvas.Left="10"
            Canvas.Top="842"
            Width="32"
            Height="32"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            RenderTransformOrigin="0.5,0.5"
            Source="img/PapaNoel/PapaNoel.gif"
            Visibility="Hidden">
            <Image.RenderTransform>
                <RotateTransform x:Name="ImageRotation" Angle="0" />
            </Image.RenderTransform>
        </Image>
        <Image
