<Window
    x:Class="Labyrinthe.dialogue_Pause"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Labyrinthe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Pause"
    Width="400"
    Height="400"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Canvas>
        <Canvas.Background>
            <ImageBrush ImageSource="/img/Fonds/fondOptions.jpg"/>
        </Canvas.Background>
        <Button x:Name="buttRepre" Content="Reprendre" Canvas.Left="150" Height="50" Width="100" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,90,0,0" Click="buttRepre_Click" Background="Black" BorderBrush="Red" Foreground="White">
            <Button.Effect>
                <DropShadowEffect/>
            </Button.Effect>
        </Button>
        <Button x:Name="buttAccueil" Content="Accueil" Canvas.Left="150" Width="100" Height="50" Click="buttAccueil_Click" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,230,0,0" Background="Black" BorderBrush="Red" Foreground="White">
            <Button.Effect>
                <DropShadowEffect/>
            </Button.Effect>
        </Button>
        <Button x:Name="butQuitt" Content="Quitter" Canvas.Left="150" Width="100" Height="50" Click="butQuitt_Click" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,300,0,0" Background="Black" BorderBrush="Red" Foreground="White">
            <Button.Effect>
                <DropShadowEffect/>
            </Button.Effect>
        </Button>
        <Button x:Name="buttOption_pause" Content="Option" Canvas.Left="150" Height="50" Width="100" HorizontalAlignment="Center" VerticalAlignment="Top" Click="buttOption_pause_Click" Margin="0,160,0,0" Foreground="White" BorderBrush="Red" Background="Black">
            <Button.Effect>
                <DropShadowEffect/>
            </Button.Effect>
        </Button>
    </Canvas>

</Window>
