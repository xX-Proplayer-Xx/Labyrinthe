<Window
    x:Class="Labyrinthe.Menu_Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Labyrinthe"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Options"
    Width="300"
    Height="300"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Canvas Background="#FFD8D8FF">
        <Button Content="Ok" Width="100" Height="25"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Click="CloseButton_Click" Canvas.Left="100" Canvas.Top="191"/>
        <Label Content="Volume Musique" Canvas.Left="20" Canvas.Top="86" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Slider Name="VolumeSlider"
                        Minimum="0"
                        Maximum="1"
                        Width="130"
                        ValueChanged="VolumeSlider_ValueChanged" Canvas.Left="140" Canvas.Top="90" HorizontalAlignment="Center" VerticalAlignment="Top"/>
    </Canvas>

</Window>
